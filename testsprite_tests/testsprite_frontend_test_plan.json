  {
    "id": "TC001",
    "title": "Create a new product and verify it appears in the products table",
    "description": "Verifies an admin can add a product via the form and see it listed in the products table.",
    "category": "Admin Products Management",
    "priority": "High",
    "steps": [
      {
        "type": "action",
        "description": "Navigate to /admin/login"
      },
      {
        "type": "action",
        "description": "Type \"{{LOGIN_USER}}\" into the username/email field"
      },
      {
        "type": "action",
        "description": "Type \"{{LOGIN_PASSWORD}}\" into the password field"
      },
      {
        "type": "action",
        "description": "Click the \"Sign in\" button"
      },
      {
        "type": "assertion",
        "description": "Verify URL contains \"/admin\""
      },
      {
        "type": "action",
        "description": "Click on \"Products\" in the admin navigation"
      },
      {
        "type": "action",
        "description": "Click the \"Add Product\" button"
      },
      {
        "type": "assertion",
        "description": "Verify text \"Add Product\" is visible"
      }
    ]
  },
