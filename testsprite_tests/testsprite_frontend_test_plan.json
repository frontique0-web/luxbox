    "steps": [
      {
        "type": "action",
        "description": "Navigate to /admin/login"
      },
      {
        "type": "action",
        "description": "Type \"{{LOGIN_USER}}\" into the username or email field"
      },
      {
        "type": "action",
        "description": "Type \"{{LOGIN_PASSWORD}}\" into the password field"
      },
      {
        "type": "action",
        "description": "Click the \"Sign in\" or \"Login\" button"
      },
      {
        "type": "action",
        "description": "Click the \"Settings\" link or menu item in the admin navigation"
      },
      {
        "type": "action",
        "description": "Fill \"Acme Test Store\" into the Store Name field"
